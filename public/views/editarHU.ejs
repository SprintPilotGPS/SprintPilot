<!DOCTYPE html>
<html lang="es">
  <head>
    <%- include('./partials/head') %>
    <title><%= title %></title>
  </head>

  <body>
    <%- include('./partials/navbar') %>
    <div class="container mt-5">
        <h2>Editar HU</h2>
        <form action="/api/<%= project_id %>/hus/update/<%= hu._id %>" method="POST">
            <div class="mb-3">
                <label for="identificador" class="form-label">ID</label>
                <input type="number" id="identificador" name="identificador" value="<%= hu.identificador %>" class="form-control" readonly>
            </div>
            <div class="mb-3">
                <label for="titulo" class="form-label">Título</label>
                <input type="text" id="titulo" name="titulo" value="<%= hu.titulo %>" class="form-control" required>
            </div>
            <div class="mb-3">
                <label for="descripcion" class="form-label">Descripción</label>
                <textarea id="descripcion" name="descripcion" class="form-control" rows="4"><%= hu.descripcion %></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                <a href="/<%= project_id %>/backlog" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
    <%- include('./partials/footer') %>
  </body>
</html>