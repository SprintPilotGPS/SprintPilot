<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Nuevo Proyecto - SprintPilot</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body style="background-color: #6a5acd; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0;">

    <div class="form-card" style="background: white; padding: 30px; border-radius: 12px; width: 400px; box-shadow: 8px 8px 0px rgba(0,0,0,0.1);">
        <h2 style="margin-top: 0; font-family: sans-serif;">Nuevo Proyecto</h2>
        
        <form id="projectForm" action="/api/proyectos" method="POST">
            
            <div class="form-group" style="margin-bottom: 15px; display: flex; flex-direction: column;">
                <label for="nombre" style="font-weight: bold; margin-bottom: 5px; font-family: sans-serif;">Proyecto (Nombre)</label>
                <input type="text" id="nombre" name="nombre" required style="padding: 10px; border: 1px solid #ccc; border-radius: 6px;">
            </div>

            <div class="form-group" style="margin-bottom: 15px; display: flex; flex-direction: column;">
                <label for="identificador" style="font-weight: bold; margin-bottom: 5px; font-family: sans-serif;">ID del Proyecto</label>
                <input type="text" id="identificador" name="identificador" placeholder="Ej: PR-01" required style="padding: 10px; border: 1px solid #ccc; border-radius: 6px;">
            </div>

            <div class="form-group" style="margin-bottom: 20px; display: flex; flex-direction: column;">
                <label for="descripcion" style="font-weight: bold; margin-bottom: 5px; font-family: sans-serif;">Descripción</label>
                <textarea id="descripcion" name="descripcion" rows="3" placeholder="Describe el contenido..." required style="padding: 10px; border: 1px solid #ccc; border-radius: 6px; font-family: sans-serif; resize: none;"></textarea>
            </div>

            <div class="form-actions" style="display: flex; align-items: center; gap: 15px;">
                <button type="submit" class="btn-save" style="background-color: #3498db; color: white; border: none; padding: 12px 20px; border-radius: 6px; cursor: pointer; font-weight: bold;">Guardar Proyecto</button>
                <a href="/" class="btn-cancel" style="color: #e74c3c; text-decoration: none; font-family: sans-serif; font-size: 0.9em;">Cancelar</a>
            </div>
        </form>
    </div>

    <script src="/js/projectValidation.js"></script>
</body>
</html>