<!DOCTYPE html>
<html lang="es">
<head>
<%- include('./partials/head') %>
</head>

<body>
    <!-- navbar -->
    <%- include('./partials/navbar') %>

    <!-- main container -->
    <div class="container-lg main-container">
        

        <!-- tabla de requisitos -->
        <div class="table-card">
            <div class="table-header">📊 Tareas de Sprint Recientes</div>
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID de Tarea</th>
                        <th>Nombre de Tarea</th>
                        <th>Prioridad</th>
                        <th>Estado</th>
                        <th>Responsable</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (requisitos && requisitos.length > 0) { %>
                        <% requisitos.forEach(function(req) { %>
                            <tr>
                                <td><%= req.identificador %></td>
                                <td><%= req.nombre %></td>
                                <td><%= req.prioridadIcono %> <%= req.prioridad %></td>
                                <td><span class="status-badge <%= req.estadoClase %>"><%= req.estado %></span></td>
                                <td><%= req.responsable %></td>
                                <td>
                                    <div class="action-buttons">
                                        <button class="btn btn-sm btn-view" onclick="viewRequisito('<%= req._id %>')">Ver</button>
                                        <button class="btn btn-sm btn-edit" onclick="editRequisito('<%= req._id %>')">Editar</button>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                No hay datos de tareas, por favor agregue una nueva tarea
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- footer -->
    <footer>
        <p>&copy; 2026 Sprint Pilot. All rights reserved.</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
    <script src="/js/main.js"></script>
</body>
</html>