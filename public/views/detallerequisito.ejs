<%- include('./partials/head') %>
<%- include('./partials/navbar') %>
<div class="container mt-5">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h2>Detalle: <%= requisito.nombre %></h2>
        </div>
        <div class="card-body">
            <p><strong>Estado:</strong> <%= requisito.estado %></p>
            <p><strong>Prioridad:</strong> <%= requisito.prioridad %></p>
            <p><strong>Descripción:</strong> <%= requisito.descripcion %></p>
        </div>
        <div class="card-footer">
            <a href="/<%= requisito.project_id %>/backlog" class="btn btn-secondary">Volver</a>
        </div>
    </div>
</div>
<%- include('./partials/footer') %>