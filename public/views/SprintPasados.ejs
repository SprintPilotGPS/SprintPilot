<!DOCTYPE html>
<html lang="es">
  <head>
    <%- include('partials/head') %>
    <title><%= title %></title>
    <style>
      .sprint-card {
        transition: transform 0.2s, box-shadow 0.2s;
        cursor: pointer;
      }
      .sprint-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.2) !important;
      }
      .sprint-number {
        font-size: 2.5rem;
        font-weight: 800;
        opacity: 0.2;
        position: absolute;
        right: 20px;
        top: 10px;
      }
    </style>
  </head>
  <body>
    <%- include('partials/navbar') %>

    <div class="container main-container">
      <div class="welcome-section">
        <h1 class="display-4 fw-bold">Sprints Pasados</h1>
        <p class="lead">Revisa el historial de trabajo completado en este proyecto.</p>
      </div>

      <div class="row row-cols-1 row-cols-md-3 g-4">
        <% if (sprints && sprints.length > 0) { %>
          <% sprints.forEach(s => { %>
            <div class="col">
              <div class="card h-100 sprint-card border-0 shadow-sm rounded-4 overflow-hidden" onclick="viewSprintDetails('<%= s.numero %>')">
                <div class="card-body p-4 position-relative">
                  <div class="sprint-number">#<%= s.numero %></div>
                  <h5 class="card-title fw-bold text-primary mb-3">Sprint <%= s.numero %></h5>
                  
                  <div class="d-flex flex-column gap-2 mb-3">
                    <div class="small text-muted">
                      <i class="bi bi-calendar-check me-2"></i>
                      Inicio: <%= new Date(s.fecha_inicio).toLocaleDateString() %>
                    </div>
                    <% if (s.fecha_fin) { %>
                      <div class="small text-muted">
                        <i class="bi bi-calendar-x me-2"></i>
                        Fin: <%= new Date(s.fecha_fin).toLocaleDateString() %>
                      </div>
                    <% } %>
                  </div>

                  <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3">Completado</span>
                </div>
                <div class="card-footer bg-light border-0 py-3 text-center">
                  <span class="text-primary small fw-bold">Ver Detalles <i class="bi bi-arrow-right ms-1"></i></span>
                </div>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="col-12">
            <div class="text-center py-5 bg-white rounded-4 shadow-sm">
              <img src="https://illustrations.popsy.co/blue/astronaut-riding-a-rocket.svg" alt="No History" style="width: 250px;" class="mb-4">
              <h4 class="text-muted">Aún no hay historial</h4>
              <p class="text-muted">Los sprints aparecerán aquí una vez que los completes.</p>
              <a href="/<%= project_id %>/sprints-actual" class="btn btn-primary mt-3 rounded-pill px-4">Ir al Sprint Actual</a>
            </div>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Modal para ver detalles de un sprint pasado -->
    <div id="modal-view-sprint" class="modal-new-project">
      <div class="card shadow-lg border-0 rounded-4" style="width: 50%; max-height: 80vh;">
        <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
          <h3 class="fw-bold text-primary mb-0" id="modal-sprint-title">Detalles del Sprint</h3>
          <button type="button" class="btn-close" onclick="hideDetailsModal()"></button>
        </div>
        <div class="card-body p-4 overflow-auto">
          <div id="modal-sprint-content">
            <div class="text-center py-4">
              <div class="spinner-border text-primary" role="status"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%- include('partials/footer') %>

    <script>
      async function viewSprintDetails(numero) {
        const modal = document.getElementById("modal-view-sprint");
        const title = document.getElementById("modal-sprint-title");
        const content = document.getElementById("modal-sprint-content");
        
        modal.classList.add("show");
        title.innerText = `Detalles del Sprint #${numero}`;
        content.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>';

        try {
          const response = await fetch(`/api/<%= project_id %>/sprints/${numero}`);
          const result = await response.json();
          
          if (result.success) {
            const { hus } = result.data;
            if (hus && hus.length > 0) {
              let html = '<div class="list-group list-group-flush">';
              hus.forEach(hu => {
                html += `
                  <div class="list-group-item px-0 py-3 border-light">
                    <div class="d-flex justify-content-between">
                      <h6 class="fw-bold mb-1">HU-${hu.identificador}: ${hu.titulo}</h6>
                    </div>
                    <p class="text-muted small mb-0">${hu.descripcion || 'Sin descripción'}</p>
                  </div>
                `;
              });
              html += '</div>';
              content.innerHTML = html;
            } else {
              content.innerHTML = '<p class="text-center text-muted py-4">No se encontraron HUs en este sprint.</p>';
            }
          } else {
            content.innerHTML = `<p class="text-danger text-center py-4">${result.error}</p>`;
          }
        } catch (error) {
          content.innerHTML = '<p class="text-danger text-center py-4">Error al cargar los datos.</p>';
        }
      }

      function hideDetailsModal() {
        document.getElementById("modal-view-sprint").classList.remove("show");
      }
    </script>
  </body>
</html>