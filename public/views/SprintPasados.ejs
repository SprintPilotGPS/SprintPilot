<!DOCTYPE html>
<html lang="es">
  <head>
    <%- include('partials/head') %>
    <title><%= title %></title>
    <style>
      .sprint-card {
        transition: transform 0.2s, box-shadow 0.2s;
        cursor: pointer;
      }
      .sprint-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.2) !important;
      }
      .sprint-number {
        font-size: 2.5rem;
        font-weight: 800;
        opacity: 0.2;
        position: absolute;
        right: 20px;
        top: 10px;
      }
    </style>
  </head>
  <body>
    <%- include('partials/navbar') %>

    <div class="container main-container">
      <div class="welcome-section">
        <h1 class="display-4 fw-bold">Sprints Pasados</h1>
        <p class="lead">Revisa el historial de trabajo completado en este proyecto.</p>
      </div>

      <input type="hidden" id="project_id" value="<%= project_id %>">

      <div class="row row-cols-1 row-cols-md-3 g-4">
        <% if (sprints && sprints.length > 0) { %>
          <% sprints.forEach(s => { %>
            <div class="col">
              <div class="sprint card h-100 sprint-card border-0 shadow-sm rounded-4 overflow-hidden">
                <input type="hidden" value="<%= s.id %>">
                <div class="card-body p-4 position-relative">
                  <div class="sprint-number">#<%= s.id %></div>
                  <h5 class="card-title fw-bold text-primary mb-3">Sprint <%= s.id %></h5>
                  
                  <div class="d-flex gap-4">
                    <p class="fs-6 fw-bold text-secondary">
                      Inicio: <%= new Date(s.fechaIni).toLocaleDateString("es-ES") %>
                    </p>
                    <p class="fs-6 fw-bold text-secondary">
                      Fin: <%= new Date(s.fechaFin).toLocaleDateString("es-ES") %>
                    </p>
                  </div>
                  <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3">Completado</span>
                </div>
                <div class="card-footer bg-light border-0 py-3 text-center">
                  <span class="text-primary small fw-bold">Ver Detalles <i class="bi bi-arrow-right ms-1"></i></span>
                </div>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="col-12">
            <div class="text-center py-5 bg-white rounded-4 shadow-sm">
              <img src="https://illustrations.popsy.co/blue/astronaut-riding-a-rocket.svg" alt="No History" style="width: 250px;" class="mb-4">
              <h4 class="text-muted">Aún no hay historial</h4>
              <p class="text-muted">Los sprints aparecerán aquí una vez que los completes.</p>
              <a href="/<%= project_id %>/sprint-actual" class="btn btn-primary mt-3 rounded-pill px-4">Ir al Sprint Actual</a>
            </div>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Modal para ver detalles de un sprint pasado -->
    <div id="modal-view-sprint" class="modal-new-project">
      <div class="card shadow-lg border-0 rounded-4" style="width: 50%; max-height: 80vh;">
        <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
          <h3 class="fw-bold text-primary mb-0" id="modal-sprint-title">Detalles del Sprint</h3>
          <button type="button" class="btn-close" onclick="hideDetailsModal()"></button>
        </div>
        <div class="card-body p-4 overflow-auto">
          <div id="modal-sprint-content">
            <div class="text-center py-4">
              <div class="spinner-border text-primary" role="status"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%- include('partials/footer') %>

    <script src="/js/sprintPasadosValidation.js"></script>
  </body>
</html>