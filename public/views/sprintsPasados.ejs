<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('./partials/head') %>
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    /* Sprints Pasados */
    .sprint-card {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      border-radius: 16px;
      overflow: hidden;
    }
    .sprint-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 12px 40px rgba(0,0,0,0.12) !important;
    }
    .sprint-goal-container {
      border-left: 4px solid var(--primary-color);
    }
  </style>
</head>
<body>
  <%- include('./partials/navbar') %>

  <div class="container-lg main-container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
      <h2 class="fw-bold mb-0 text-dark">Sprints Pasados</h2>
      <a href="/<%= project_id %>/backlog" class="btn btn-outline-primary">
        <i class="bi bi-arrow-left"></i> Volver al Backlog / Sprint Actual
      </a>
    </div>

    <% if (sprints && sprints.length > 0) { %>
      <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        <% sprints.forEach(function(sprint) { %>
          <div class="col">
            <div class="card h-100 sprint-card border-0 shadow-sm">
              <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center pt-4 pb-2 px-4">
                <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill">Completado</span>
                <span class="text-muted small fw-medium">
                  <%= sprint.fecha_inicio %> - <%= sprint.fecha_fin %>
                </span>
              </div>
              <div class="card-body px-4 py-3">
                <h4 class="card-title fw-bold text-dark mb-3"><%= sprint.nombre %></h4>
                <div class="sprint-goal-container bg-light rounded-3 p-3 mb-4">
                  <span class="d-block text-uppercase text-muted small fw-bold mb-1">Sprint Goal</span>
                  <p class="card-text text-dark mb-0"><%= sprint.goal %></p>
                </div>
                
                <div class="stats-row d-flex justify-content-between align-items-center mb-1">
                  <div class="stat-item text-center">
                    <span class="d-block h4 mb-0 fw-bold text-primary"><%= sprint.total_hus %></span>
                    <span class="small text-muted">Total HUs</span>
                  </div>
                  <div class="stat-divider bg-secondary opacity-25" style="width: 1px; height: 30px;"></div>
                  <div class="stat-item text-center">
                    <span class="d-block h4 mb-0 fw-bold text-success"><%= sprint.hus_completadas %></span>
                    <span class="small text-muted">Completadas</span>
                  </div>
                </div>
              </div>
              <div class="card-footer bg-transparent border-top-0 px-4 pb-4">
                <!-- Example of progress bar -->
                <div class="progress" style="height: 6px;">
                  <% const percentage = sprint.total_hus > 0 ? Math.round((sprint.hus_completadas / sprint.total_hus) * 100) : 0; %>
                  <div class="progress-bar bg-success" role="progressbar" style="width: <%= percentage %>%" aria-valuenow="<%= percentage %>" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                <div class="text-end mt-2">
                  <small class="text-success fw-bold"><%= percentage %>% Completado</small>
                </div>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="alert alert-light border shadow-sm text-center py-5">
        <h4 class="alert-heading fw-bold mb-3">No hay sprints pasados</h4>
        <p class="text-muted mb-0">Todavía no se ha cerrado ningún sprint en este proyecto.</p>
      </div>
    <% } %>
  </div>

  <%- include('./partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
