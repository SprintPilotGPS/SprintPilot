<!DOCTYPE html>
<html lang="es">
  <head>
    <%- include('partials/head') %>
    <title><%= title %></title>
    <style>
      .hu-card {
        transition:
          transform 0.2s,
          box-shadow 0.2s;
        border-left: 5px solid var(--primary-color) !important;
      }
      .hu-card:hover {
        transform: translateX(5px);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1) !important;
      }
      .planning-section {
        background: #fff;
        border-radius: 15px;
        padding: 25px;
        margin-bottom: 30px;
        border-left: 8px solid var(--primary-color);
      }
      .planning-label {
        font-weight: 700;
        color: #4a5568;
        min-width: 120px;
        display: inline-block;
      }
      .planning-input {
        border: none;
        border-bottom: 2px solid #e2e8f0;
        border-radius: 0;
        padding: 5px 10px;
        transition: border-color 0.3s;
        width: 100%;
        background: transparent;
      }
      .planning-input:focus {
        outline: none;
        border-bottom-color: var(--primary-color);
        box-shadow: none;
      }
    </style>
  </head>
  <body>
    <%- include('partials/navbar') %>

    <div class="container main-container">
      <div class="welcome-section">
        <h1 class="display-4 fw-bold">Sprint Actual</h1>
        <p class="lead">Visualiza y gestiona las Historias de Usuario de tu ciclo actual.</p>
      </div>

      <div class="table-card border-0">
        <div class="table-header d-flex justify-content-between align-items-center rounded-top">
          <div class="d-flex align-items-center">
            <span class="fs-4 me-2">🚀</span>
            <% if (sprint) { %>
            <span class="fs-3">Sprint #<%= sprint.id %></span>
            <input type="hidden" id="sprintId" value="<%= sprint.id %>">
            <% } else { %>
            <span>Sin Sprint Activo</span>
            <% } %>
          </div>
          <button class="openModalSprintCreate btn btn-light btn-sm fw-bold px-3 rounded-pill">
            + Nuevo Sprint
          </button>
        </div>

        <div class="p-4 bg-light min-vh-50">
          <% if (sprint) { %>
          <div class="planning-section shadow-sm">
            <div class="mb-0">
              <div class="d-flex align-items-center">
                <span class="planning-label">Sprint Goal:</span>
                <div class="flex-grow-1 ms-3">
                  <input
                    id="sprintGoal"
                    type="text"
                    class="planning-input"
                    placeholder="Ej: Implementar el sistema de pagos y autenticación"
                    value="<%= sprint.sprintGoal %>"
                  />
                </div>
              </div>
            </div>
          </div>
          <% } %>

          <% if (sprint && hus.length > 0) { %>
          <div class="row row-cols-1 row-cols-md-2 g-4">
            <% hus.forEach(hu => { %>
            <div class="col">
              <div class="card h-100 hu-card shadow-sm border-0 rounded-3">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle"
                      >HU-<%= hu.identificador %></span
                    >
                  </div>
                  <h5 class="card-title fw-bold text-dark"><%= hu.titulo %></h5>
                  <p class="card-text text-muted small"><%= hu.descripcion %></p>
                </div>
                <div class="card-footer bg-transparent border-0 pt-0 pb-3">
                  <a
                    href="/<%= project_id %>/hus/<%= hu.identificador %>/view"
                    class="btn btn-outline-primary btn-sm rounded-pill px-3"
                    >Ver Detalle</a
                  >
                </div>
              </div>
            </div>
            <% }) %>
          </div>
          <% } else if (sprint) { %>
          <div class="text-center py-5">
            <h4 class="text-muted">No hay HUs en este sprint</h4>
            <p class="text-muted">Este sprint está vacío. ¡Ánimo con la planificación!</p>
          </div>
          <% } else { %>
          <div class="text-center py-5">
            <h4 class="text-muted">¡Listos para despegar!</h4>
            <p class="text-muted">No hay ningún sprint activo.</p>
            <button class="openModalSprintCreate btn btn-primary mt-3 rounded-pill px-4">
              Iniciar Primer Sprint
            </button>
          </div>
          <% } %>
        </div>
      </div>

      <div class="text-center mt-5 mb-5">
        <a
          href="/<%= project_id %>/sprints-pasados"
          class="sprints-pasados-link fs-4 text-white hover-opacity-100"
        >
          Ver historial de sprints pasados
        </a>
      </div>
    </div>

    <%- include('partials/formSprint') %>
    <%- include('partials/footer') %>

    <script src="/js/sprintValidation.js"></script>
  </body>
</html>
