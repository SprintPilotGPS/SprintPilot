<!DOCTYPE html>
<html lang="es">
  <head>
    <%- include('partials/head') %>
    <title><%= title %></title>
    <style>
      .hu-card {
        transition: transform 0.2s, box-shadow 0.2s;
        border-left: 5px solid var(--primary-color) !important;
      }
      .hu-card:hover {
        transform: translateX(5px);
        box-shadow: 0 4px 15px rgba(0,0,0,0.1) !important;
      }
    </style>
  </head>
  <body>
    <%- include('partials/navbar') %>

    <div class="container main-container">
      <div class="welcome-section">
        <h1 class="display-4 fw-bold">Sprint Actual</h1>
        <p class="lead">Visualiza y gestiona las Historias de Usuario de tu ciclo actual.</p>
      </div>

      <div class="table-card border-0">
        <div class="table-header d-flex justify-content-between align-items-center rounded-top">
          <div class="d-flex align-items-center">
            <span class="fs-4 me-2">🚀</span>
            <% if (sprint) { %>
            <input type="hidden" id="current_sprint_id" value="<%= sprint.id %>">
            <span class="fs-3">Sprint #<%= sprint.id %></span>
            <button class="btn btn-light btn-sm fw-bold px-3 ms-4 rounded-pill" id="openAddHUModal">Añadir</button>
            <% } else { %>
            <span>Sin Sprint Activo</span>
            <% } %>
          </div>
          <button class="openModalSprintCreate btn btn-light btn-sm fw-bold px-3 rounded-pill">+ Nuevo Sprint</button>
        </div>

        <div class="p-4 bg-light min-vh-50">
          <% if (sprint && hus.length > 0) { %>
            <div class="row row-cols-1 row-cols-md-2 g-4">
              <% hus.forEach(hu => { %>
                <div class="col">
                  <div class="card h-100 hu-card shadow-sm border-0 rounded-3">
                    <div class="card-body">
                      <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle">HU-<%= hu.identificador %></span>
                      </div>
                      <h5 class="card-title fw-bold text-dark"><%= hu.titulo %></h5>
                      <p class="card-text text-muted small"><%= hu.descripcion %></p>
                    </div>
                    <div class="card-footer bg-transparent border-0 pt-0 pb-3">
                      <a href="/<%= project_id %>/hus/<%= hu.identificador %>/view" class="btn btn-outline-primary btn-sm rounded-pill px-3">Ver Detalle</a>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } else if (sprint) { %>
            <div class="text-center py-5">
              <h4 class="text-muted">No hay HUs en este sprint</h4>
              <p class="text-muted">Este sprint está vacío. ¡Ánimo con la planificación!</p>
            </div>
          <% } else { %>
            <div class="text-center py-5">
              <h4 class="text-muted">¡Listos para despegar!</h4>
              <p class="text-muted">No hay ningún sprint activo.</p>
              <button class="openModalSprintCreate btn btn-primary mt-3 rounded-pill px-4">Iniciar Primer Sprint</button>
            </div>
          <% } %>
        </div>
      </div>

      <div class="text-center mt-5 mb-5">
        <a href="/<%= project_id %>/sprints-pasados" class="sprints-pasados-link fs-4 text-white hover-opacity-100">
          Ver historial de sprints pasados
        </a>
      </div>
    </div>

    <%- include('partials/formSprint') %>
    
    <!-- Modal Añadir HU -->
    <div id="addHUModal" class="modal-new-project">
      <div class="rounded border border-3 border-black bg-white" style="width: 400px; padding: 20px;">
        <h2 class="text-center mb-4">Añadir HU</h2>
        <div class="mb-4" style="max-height: 300px; overflow-y: auto;">
          <% if (backlog && backlog.length > 0) { %>
            <table class="table table-sm">
              <tbody>
                <% backlog.forEach(hu => { %>
                  <tr>
                    <td>
                      <input class="form-check-input hu-checkbox-add" type="checkbox" value="<%= hu.identificador %>" id="add_hu_<%= hu.identificador %>">
                    </td>
                    <td>
                      <label class="form-check-label small fw-bold" for="add_hu_<%= hu.identificador %>">
                        HU-<%= hu.identificador %>: <%= hu.titulo %>
                      </label>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } else { %>
            <p class="text-center text-muted">No hay HUs disponibles en el backlog.</p>
          <% } %>
        </div>
        <div class="d-flex justify-content-around">
          <button class="btn btn-primary px-4" id="saveAddHU">Añadir</button>
          <button class="btn btn-danger px-4" id="closeAddHUModal">Cancelar</button>
        </div>
      </div>
    </div>

    <%- include('partials/footer') %>

    <script src="/js/sprintValidation.js"></script>
  </body>
</html>