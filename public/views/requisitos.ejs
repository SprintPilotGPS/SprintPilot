<!DOCTYPE html>
<html lang="es">
  <head>
    <%- include('./partials/head', { pageStyles: ['requisitosCss'] }) %>
  </head>

  <body>
    <!-- navbar -->
    <%- include('./partials/navbar') %>

    <!-- main container -->
    <div class="container-lg main-container">
      <!-- tabla de requisitos -->
      <div class="table-card">
        <div class="table-header d-flex justify-content-between align-items-center gap-2 flex-wrap">
          <span>Backlog de proyecto: Requisitos</span>
          <button
            type="button"
            class="btn btn-light btn-sm"
            data-bs-toggle="modal"
            data-bs-target="#addRequisitoModal"
          >
            Add Requisito
          </button>
        </div>
        <table class="table table-hover">
          <thead>
            <tr>
              <th>ID de Tarea</th>
              <th>Nombre de Requisito</th>
              <th class="text-center">Prioridad</th>
              <th class="text-center">Estado</th>
              <th class="text-center">Responsable</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody id="table-body">
            <% if (requisitos && requisitos.length > 0) { %>
            <% requisitos.forEach(function(req) { %>
            <tr>
              <td><%= project_id + "-" + req.identificador %></td>
              <td><%= req.nombre %></td>
              <td class="text-center">
                <span class="badge fw-bold 
                  <% if(req.prioridad.toLowerCase() == "high") { %>bg-danger
                  <% } else if(req.prioridad.toLowerCase() == "medium") { %>bg-warning
                  <% } else { %>
                  bg-info
                  <% } %>">
                  <%= req.prioridad %>
                </span>
              </td>
              <td class="text-center">
                <span class="status-badge fw-bold text-white
                  <% if(req.estado.toLowerCase() == "pending") { %>
                  bg-secondary
                  <% } else if(req.estado.toLowerCase() == "in-progress") { %>
                  bg-primary
                  <% } else { %>
                  bg-success
                  <% } %>
                  "><%= req.estado %>
                </span>
              </td>
              <td><%= req.responsable %></td>
              <td>
                <div class="action-buttons">
                  <button class="btn btn-sm btn-light" onclick="moverArriba('<%= req._id %>')">
                    ⬆️
                  </button>
                  <button class="btn btn-sm btn-light" onclick="moverAbajo('<%= req._id %>')">
                    ⬇️
                  </button>
                  <button class="btn btn-sm btn-view" onclick="viewRequisito('<%= req._id %>')">
                    Ver
                  </button>
                  <button class="btn btn-sm btn-edit" onclick="editRequisito('<%= req._id %>')">
                    Editar
                  </button>
                </div>
              </td>
            </tr>
            <% }); %>
            <% } else { %>
            <tr id="empty">
              <td colspan="7" class="text-center text-muted py-4">
                No hay datos de tareas, por favor agregue una nueva tarea
              </td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Modal: Add Requisito -->
    <div
      class="modal fade"
      id="addRequisitoModal"
      tabindex="-1"
      aria-labelledby="addRequisitoModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="addRequisitoModalLabel">Add Requisito</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
              aria-label="Close"
            ></button>
          </div>
          <form id="addRequisitoForm">
            <div class="modal-body">
              <div class="row g-3">
                <div class="col-12">
                  <label for="nombre" class="form-label">Nombre de Tarea</label>
                  <input type="text" class="form-control" id="nombre" name="nombre" required />
                </div>

                <div class="col-md-6">
                  <label for="responsable" class="form-label">Responsable</label>
                  <input type="text" class="form-control" id="responsable" name="responsable" />
                </div>

                <div class="col-md-6">
                  <label for="prioridad" class="form-label">Prioridad</label>
                  <select class="form-select" id="prioridad" name="prioridad">
                    <option value="medium" selected>Medium</option>
                    <option value="high">High</option>
                    <option value="low">Low</option>
                  </select>
                </div>
                <div class="col-md-6">
                  <label for="estado" class="form-label">Estado</label>
                  <select class="form-select" id="estado" name="estado">
                    <option value="pending" selected>Pending</option>
                    <option value="in-progress">In Progress</option>
                    <option value="completed">Completed</option>
                  </select>
                </div>
                <div class="col-12">
                  <label for="descripcion" class="form-label">Descripcion</label>
                  <textarea
                    class="form-control"
                    id="descripcion"
                    name="descripcion"
                    rows="3"
                    placeholder="Detalle opcional"
                  ></textarea>
                </div>
                <input id="project_id" type="hidden" value="<%= project_id %>" />
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                Cancelar
              </button>
              <button type="submit" class="btn btn-primary">Guardar</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- footer -->
    <%- include('./partials/footer') %>
    <div id="noti" class="noti"></div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script
      src="https://code.jquery.com/jquery-3.7.1.min.js"
      integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo="
      crossorigin="anonymous"
    ></script>
    <script src="/js/requisitosValidation.js"></script>
