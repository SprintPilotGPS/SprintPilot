<!DOCTYPE html>
<html lang="es">
  <head>
    <%- include('./partials/head') %>
  </head>

  <body>
    <%- include('./partials/navbar') %>

    <div class="container-lg main-container">
      <div class="table-card">
        <div class="table-header d-flex justify-content-between align-items-center gap-2 flex-wrap">
          <span>Backlog de proyecto: Requisitos</span>
          <button
            type="button"
            class="btn btn-light btn-sm"
            data-bs-toggle="modal"
            data-bs-target="#addRequisitoModal"
          >
            Add Requisito
          </button>
        </div>
        <table class="table table-hover">
          <thead>
            <tr>
              <th>ID de Tarea</th>
              <th>Nombre de Requisito</th>
              <th>Prioridad</th>
              <th>Estado</th>
              <th>Responsable</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (requisitos && requisitos.length > 0) { %>
            <% requisitos.forEach(function(req) { %>
            <tr>
              <td><%= project_id + "-" + req.identificador %></td>
              <td><%= req.nombre %></td>
              <td>
                <%= req.prioridadIcono %>
                <%= req.prioridad %>
              </td>
              <td><span class="status-badge <%= req.estadoClase %>"><%= req.estado %></span></td>
              <td><%= req.responsable %></td>
              <td>
                <div class="action-buttons">
                  <button class="btn btn-sm btn-light" onclick="moverArriba('<%= req._id %>')">
                    ⬆️
                  </button>
                  <button class="btn btn-sm btn-light" onclick="moverAbajo('<%= req._id %>')">
                    ⬇️
                  </button>
                  <button class="btn btn-sm btn-view" onclick="viewRequisito('<%= req._id %>')">
                    Ver
                  </button>
                  <button class="btn btn-sm btn-edit" onclick="editRequisito('<%= req._id %>')">
                    Editar
                  </button>
                </div>
              </td>
            </tr>
            <% }); %>
            <% } else { %>
            <tr>
              <td colspan="7" class="text-center text-muted py-4">
                No hay datos de tareas, por favor agregue una nueva tarea
              </td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <div
      class="modal fade"
      id="addRequisitoModal"
      tabindex="-1"
      aria-labelledby="addRequisitoModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="addRequisitoModalLabel">Add Requisito</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
              aria-label="Close"
            ></button>
          </div>
          <form id="addRequisitoForm">
            <div class="modal-body">
              <div class="row g-3">
                <div class="col-12">
                  <label for="nombre" class="form-label">Nombre de Tarea</label>
                  <input type="text" class="form-control" id="nombre" name="nombre" required />
                </div>

                <div class="col-md-6">
                  <label for="responsable" class="form-label">Responsable</label>
                  <input
                    type="text"
                    class="form-control"
                    id="responsable"
                    name="responsable"
                  />
                </div>

                <div class="col-md-6">
                  <label for="prioridad" class="form-label">Prioridad</label>
                  <select class="form-select" id="prioridad" name="prioridad">
                    <option value="medium" selected>Medium</option>
                    <option value="high">High</option>
                    <option value="low">Low</option>
                  </select>
                </div>
                <div class="col-md-6">
                  <label for="estado" class="form-label">Estado</label>
                  <select class="form-select" id="estado" name="estado">
                    <option value="pending" selected>Pending</option>
                    <option value="in-progress">In Progress</option>
                    <option value="completed">Completed</option>
                  </select>
                </div>
                <div class="col-12">
                  <label for="descripcion" class="form-label">Descripcion</label>
                  <textarea
                    class="form-control"
                    id="descripcion"
                    name="descripcion"
                    rows="3"
                    placeholder="Detalle opcional"
                  ></textarea>
                </div>
                <input id="project_id" name="project_id" type="hidden" value="<%= project_id %>">
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                Cancelar
              </button>
              <button type="submit" class="btn btn-primary">Guardar</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <%- include('./partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script
      src="https://code.jquery.com/jquery-3.7.1.min.js"
      integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo="
      crossorigin="anonymous"
    ></script>

    <script>
      // 1. Lógica de Flechas (Movimiento)
      async function moverArriba(id) {
        try {
          const response = await fetch(`/api/requisitos/${id}/mover-arriba`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
          });
          if (response.ok) location.reload();
          else alert("No se puede subir más este requisito");
        } catch (error) { console.error("Error:", error); }
      }

      async function moverAbajo(id) {
        try {
          const response = await fetch(`/api/requisitos/${id}/mover-abajo`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
          });
          if (response.ok) location.reload();
          else alert("No se puede bajar más este requisito");
        } catch (error) { console.error("Error:", error); }
      }

      // 2. Lógica de Guardado (SIN DUPLICADOS)
      // Usamos .onsubmit para asegurarnos de que solo haya un controlador de evento
      const form = document.getElementById('addRequisitoForm');
      if (form) {
        form.onsubmit = async (e) => {
          e.preventDefault();
          e.stopImmediatePropagation();

          const projectId = document.getElementById('project_id').value;
          const formData = new FormData(form);
          const data = Object.fromEntries(formData.entries());

          try {
            const response = await fetch(`/api/${projectId}/requisitos`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data)
            });

            if (response.ok) {
              location.reload();
            } else {
              const result = await response.json();
              alert(result.error || "Error al guardar");
            }
          } catch (error) {
            console.error("Error:", error);
          }
        };
      }

      // 3. Funciones de navegación
      function viewRequisito(id) { window.location.href = `/requisitos/${id}`; }
      function editRequisito(id) { window.location.href = `/requisitos/edit/${id}` }
    </script>
  </body>
</html>