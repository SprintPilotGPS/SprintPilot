<!DOCTYPE html>
<html lang="es">
  <head>
    <%- include('./partials/head') %>
    <title><%= title %></title>
    <!-- Font Awesome para los iconos -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <style>
      .detalle-container {
        width: 80%;
        margin: auto;
      }
      .hu-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
        overflow: hidden;
        border: none;
      }
      .hu-header {
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
        color: white;
        padding: 25px 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .hu-badge {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(5px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        padding: 8px 15px;
        border-radius: 20px;
        font-weight: bold;
        font-size: 1.1rem;
      }
      .hu-title {
        margin: 0;
        font-weight: 700;
        font-size: 1.8rem;
        flex-grow: 1;
        margin-left: 20px;
      }
      .hu-body {
        padding: 30px;
      }
      .section-title {
        color: var(--secondary-color);
        font-weight: 700;
        font-size: 1.2rem;
        margin-bottom: 15px;
        border-bottom: 2px solid #f0f0f0;
        padding-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .hu-desc-box {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 20px;
        color: #495057;
        font-size: 1.05rem;
        line-height: 1.6;
        margin-bottom: 30px;
        border-left: 4px solid var(--primary-color);
      }
      .ca-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .ca-item {
        background: white;
        border: 1px solid #e9ecef;
        border-radius: 8px;
        padding: 15px 20px;
        margin-bottom: 10px;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.02);
        display: flex;
        align-items: flex-start;
        gap: 15px;
        transition: transform 0.2s;
      }
      .ca-item:hover {
        transform: translateX(5px);
        border-color: var(--primary-color);
      }
      .ca-icon {
        color: var(--success-color);
        margin-top: 3px;
      }
      .empty-state {
        text-align: center;
        padding: 30px;
        color: #6c757d;
        background: #f8f9fa;
        border-radius: 10px;
        border: 2px dashed #dee2e6;
        font-style: italic;
      }
      .action-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 20px;
      }
    </style>
  </head>

  <body>
    <%- include('./partials/navbar') %>

    <main class="detalle-container">
      <!-- Botón de volver superior -->
      <div class="mb-3">
        <a
          href="/<%= hu.project_id %>/backlog"
          class="btn btn-secondary fw-bold rounded-pill"
        >
          <i class="fa-solid fa-arrow-left me-2"></i> Volver al Backlog
        </a>
      </div>

      <div class="card hu-card">
        <!-- Cabecera -->
        <div class="hu-header">
          <div class="hu-badge shadow-sm">
            <i class="fa-solid fa-tag me-2"></i
            ><%= project_id + "-" + hu.identificador %>
          </div>
          <h2 class="hu-title text-truncate" title="<%= hu.titulo %>"><%= hu.titulo %></h2>
          <!-- Opcional: Botón editar en la cabecera como en el diseño -->
          <a
            href="/<%= project_id %>/hus/<%= hu.identificador %>/edit"
            class="btn btn-light btn-sm fw-bold shadow-sm rounded-pill px-3"
          >
            <i class="fa-solid fa-pen me-2"></i>Editar
          </a>
        </div>

        <!-- Cuerpo de la tarjeta -->
        <div class="hu-body">
          <!-- Descripción -->
          <h4 class="section-title">
            <i class="fa-solid fa-align-left"></i> Descripción de la Historia
          </h4>
          <div class="hu-desc-box shadow-sm">
            <% if (hu.descripcion) { %> <%= hu.descripcion %> <% } else { %>
            <span class="text-muted fst-italic"
              >No hay descripción proporcionada para esta historia de usuario.</span
            >
            <% } %>
          </div>

          <!-- Criterios de Aceptación -->
          <div class="d-flex justify-content-between align-items-end mb-3 mt-4">
            <h4 class="section-title mb-0 border-0">
              <i class="fa-solid fa-list-check"></i> Criterios de Aceptación
            </h4>
          </div>

          <div class="ca-section mb-4">
            <% if (hu.criterios_aceptacion && hu.criterios_aceptacion.length > 0) { %>
            <ul class="ca-list">
              <% hu.criterios_aceptacion.forEach(function(ca) { %>
              <li class="ca-item">
                <i class="fa-solid fa-circle-check ca-icon"></i>
                <div><%- ca %></div>
              </li>
              <% }); %>
            </ul>
            <% } else { %>
            <div class="empty-state shadow-sm">
              <i class="fa-solid fa-clipboard-list fs-1 mb-3 text-muted opacity-50"></i>
              <p class="mb-0">Aún no se han definido Criterios de Aceptación para esta HU.</p>
            </div>
            <% } %>
          </div>

          <!-- Botón Añadir CA (inferior derecha según diseño) -->
          <div class="d-flex justify-content-end">
            <!-- Ruta oficial de vista para crear CA -->
            <a
              href="/<%= project_id %>/hus/<%= hu.identificador %>/ca/crear"
              class="btn btn-primary btn-view fw-bold px-4 py-2 shadow rounded-pill"
            >
              <i class="fa-solid fa-plus me-2"></i> Añadir Criterio
            </a>
          </div>
        </div>
      </div>
    </main>

    <%- include('./partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
