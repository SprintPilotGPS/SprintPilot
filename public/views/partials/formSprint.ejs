<dialog id="sprintModal" class="modal-new-project rounded border-2">
  <h2 class="text-center">Crear Sprint</h2>

  <form id="sprintForm">
    <div class="mb-3">
      <label class="form-label" for="fechaInicio">Fecha de inicio:</label>
      <input 
        class="form-control" 
        type="date" 
        id="fechaInicio" 
        name="fechaInicio" 
        required 
      />
    </div>

    <div class="mb-3">
      <label class="form-label" for="fechaFin">Fecha de fin:</label>
      <input 
        class="form-control" 
        type="date" 
        id="fechaFin" 
        name="fechaFin" 
        required 
      />
    </div>

    <div class="d-flex justify-content-around mt-4">
      <button class="btn btn-primary" type="submit">Crear Sprint</button>
      <button class="btn btn-danger" type="button" id="closeSprintModal">Cancelar</button>
    </div>
  </form>
</dialog>