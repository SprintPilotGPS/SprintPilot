<div id="sprintModal" class="modal-new-project">
  <div class="rounded border border-3 border-black">
    <h2 class="text-center">Crear Sprint</h2>

    <form id="sprintForm" method="POST">
      <input type="hidden" id="project_id" value="<%= project_id %>">

      <div class="mb-3 mx-3 p-2 bg-warning-subtle rounded-3">
        <p class="m-0 text-center fs-3">⚠️</p>
        <p class="text-center fw-bold">¡Una vez se inicie este sprint se finalizará el anterior y se empezará este automáticamente!</p>
      </div>

      <div class="mb-3 px-3">
        <label class="form-label" for="fechaFin">Fecha de final:</label>
        <input
          class="form-control"
          type="date"
          id="fechaFin"
          name="fechaFin"
          maxlength="50"
          required
        />
      </div>
      
      <div class="d-flex justify-content-around pb-3">
        <button class="btn btn-primary" type="submit" id="saveSprintBtn">Guardar</button>
        <button class="btn btn-danger" type="button" id="closeModal">Cancelar</button>
      </div>
    </form>
  </div>
</div>
