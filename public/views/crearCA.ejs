<!DOCTYPE html>
<html lang="es">
  <head>
    <%- include('./partials/head') %>
    <title>Sprint Pilot - Crear CA</title>
    <!-- Font Awesome para los iconos -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  </head>

  <body>
    <%- include('./partials/navbar') %>

    <main class="container ca-container">
      <div class="card">
        <div class="card-header text-center">
          <h2 class="mb-0">Crear Criterio de Aceptación</h2>
          <p class="mb-0 opacity-75">Define el comportamiento esperado para la HU</p>
        </div>
        <div class="card-body p-4">
          <form id="caForm">
            <div class="row mb-4">
              <div class="col-12 mb-3">
                <label for="como" class="form-label fw-bold text-muted text-uppercase small">
                  <i class="fa-solid fa-user-tag me-1"></i> Contexto / Rol
                </label>
                <div class="input-group">
                  <span class="input-group-text">Como...</span>
                  <input type="text" class="form-control" id="como" placeholder="ej: administrador" required>
                </div>
              </div>

              <div class="col-12 mb-3">
                <label for="si" class="form-label fw-bold text-muted text-uppercase small">
                  <i class="fa-solid fa-bolt me-1"></i> Acción / Evento
                </label>
                <div class="input-group">
                  <span class="input-group-text">Si...</span>
                  <input type="text" class="form-control" id="si" placeholder="ej: borro un usuario" required>
                </div>
              </div>

              <div class="col-12 mb-4">
                <label for="entonces" class="form-label fw-bold text-muted text-uppercase small">
                  <i class="fa-solid fa-circle-check me-1"></i> Resultado Esperado
                </label>
                <div class="input-group">
                  <span class="input-group-text">Entonces...</span>
                  <input type="text" class="form-control" id="entonces" placeholder="ej: desaparece de la lista" required>
                </div>
              </div>
            </div>

            <div class="mb-4">
              <label class="form-label fw-bold text-muted text-uppercase small">Previsualización</label>
              <div id="preview" class="preview-box">
                Empieza a escribir para ver el resultado...
              </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-4">
              <button type="button" class="btn btn-outline-secondary px-4 fw-bold" onclick="window.history.back()">
                <i class="fa-solid fa-arrow-left me-2"></i> Cancelar
              </button>
              <button type="submit" class="btn btn-primary btn-view px-5 fw-bold py-2 shadow">
                <i class="fa-solid fa-floppy-disk me-2"></i> Guardar Criterio
              </button>
            </div>
          </form>
        </div>
      </div>
    </main>

    <%- include('./partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/caValidation.js"></script>
  </body>
</html>
