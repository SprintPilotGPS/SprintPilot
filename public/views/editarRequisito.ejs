<%- include('./partials/head') %>
<%- include('./partials/navbar') %>
<div class="container mt-5">
    <h2>Editar Requisito</h2>
    <form action="/api/requisitos/update/<%= requisito._id %>" method="POST">
        <input type="text" name="nombre" value="<%= requisito.nombre %>" class="form-control mb-2">
        <textarea name="descripcion" class="form-control mb-2"><%= requisito.descripcion %></textarea>
        <button type="submit" class="btn btn-success">Guardar Cambios</button>
        <a href="javascript:history.back()" class="btn btn-danger">Cancelar</a>
    </form>
</div>
<%- include('./partials/footer') %>