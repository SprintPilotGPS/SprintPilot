<!DOCTYPE html>
<html lang="es">
  <head>
    <%- include('./partials/head') %>
    <title><%= title %></title>
  </head>

  <body>
    <%- include('./partials/navbar') %>

    <div class="container-lg main-container">
      <div class="table-card">
        <div class="table-header d-flex justify-content-between align-items-center gap-2 flex-wrap">
          <span>Backlog de proyecto: HUs</span>
          <button
            type="button"
            class="btn btn-light btn-sm"
            data-bs-toggle="modal"
            data-bs-target="#addHUModal"
          >
            Add HU
          </button>
        </div>
          <table class="table table-hover align-middle">
          <thead>
            <tr>
              <th style="width: 15%;">ID de Tarea</th>
              <th style="width: 65%;">Título</th>
              <th style="width: 20%;">Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (hus && hus.length > 0) { %>
            <% hus.forEach(function(req) { %>
            <tr>
              <td><%= project_id + "-" + req.identificador %></td>
              <td><%= req.titulo %></td>
              <td>
                <div class="action-buttons">
                  <button class="btn btn-sm btn-light move-up">
                    ⬆️
                  </button>
                  <button class="btn btn-sm btn-light move-down">
                    ⬇️
                  </button>
                  <a class="btn btn-sm btn-view" href="/<%= project_id %>/hus/<%= req.identificador %>/view">Ver</a>
                  <a class="btn btn-sm btn-edit" href="/<%= project_id %>/hus/<%= req.identificador %>/edit">Editar</a>
                  <input type="hidden" value="<%= req.identificador %>">
                </div>
              </td>
            </tr>
            <% }); %>
            <% } else { %>
            <tr>
              <td colspan="7" class="text-center text-muted py-4">
                No hay datos de tareas, por favor agregue una nueva tarea
              </td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <div
      class="modal fade"
      id="addHUModal"
      tabindex="-1"
      aria-labelledby="addHUModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="addHUModalLabel">Add HU</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
              aria-label="Close"
            ></button>
          </div>
          <form id="addHUForm">
            <div class="modal-body">
              <div class="row g-3">
                <div class="col-md-4">
                  <label for="identificador" class="form-label">ID</label>
                  <input type="number" class="form-control" id="identificador" name="identificador" placeholder="Auto" />
                </div>
                <div class="col-md-8">
                  <label for="titulo" class="form-label">Título</label>
                  <input type="text" class="form-control" id="titulo" name="titulo" required />
                </div>


                <div class="col-12">
                  <label for="descripcion" class="form-label">Descripcion</label>
                  <textarea
                    class="form-control"
                    id="descripcion"
                    name="descripcion"
                    rows="3"
                    placeholder="Detalle opcional"
                  ></textarea>
                </div>
                <input id="project_id" name="project_id" type="hidden" value="<%= project_id %>">
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                Cancelar
              </button>
              <button type="submit" class="btn btn-primary">Guardar</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <%- include('./partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script
      src="https://code.jquery.com/jquery-3.7.1.min.js"
      integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo="
      crossorigin="anonymous"
    ></script>

    <script src="/js/husValidation.js"></script>
  </body>
</html>