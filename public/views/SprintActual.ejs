<!DOCTYPE html>
<html lang="es">
  <head>
    <%- include('partials/head') %>
    <title><%= title %></title>
    <style>
      .hu-card {
        transition: transform 0.2s, box-shadow 0.2s;
        border-left: 5px solid var(--primary-color) !important;
      }
      .hu-card:hover {
        transform: translateX(5px);
        box-shadow: 0 4px 15px rgba(0,0,0,0.1) !important;
      }
    </style>
  </head>
  <body>
    <%- include('partials/navbar') %>

    <div class="container main-container">
      <div class="welcome-section">
        <h1 class="display-4 fw-bold">Sprint Actual</h1>
        <p class="lead">Visualiza y gestiona las Historias de Usuario de tu ciclo actual.</p>
      </div>

      <div class="table-card border-0">
        <div class="table-header d-flex justify-content-between align-items-center rounded-top">
          <div class="d-flex align-items-center">
            <span class="fs-4 me-2">🚀</span>
            <span>
              <% if (sprint) { %>
                Sprint #<%= sprint.numero %>
              <% } else { %>
                Sin Sprint Activo
              <% } %>
            </span>
          </div>
          <button class="btn btn-light btn-sm fw-bold px-3 rounded-pill" onclick="showModal()">+ Nuevo Sprint</button>
        </div>

        <div class="p-4 bg-light min-vh-50">
          <% if (sprint && hus.length > 0) { %>
            <div class="row row-cols-1 row-cols-md-2 g-4">
              <% hus.forEach(hu => { %>
                <div class="col">
                  <div class="card h-100 hu-card shadow-sm border-0 rounded-3">
                    <div class="card-body">
                      <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle">HU-<%= hu.identificador %></span>
                      </div>
                      <h5 class="card-title fw-bold text-dark"><%= hu.titulo %></h5>
                      <p class="card-text text-muted small"><%= hu.descripcion %></p>
                    </div>
                    <div class="card-footer bg-transparent border-0 pt-0 pb-3">
                      <a href="/<%= project_id %>/hus/<%= hu.identificador %>/view" class="btn btn-outline-primary btn-sm rounded-pill px-3">Ver Detalle</a>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } else if (sprint) { %>
            <div class="text-center py-5">
              <img src="https://illustrations.popsy.co/blue/waiting.svg" alt="Empty" style="width: 150px;" class="mb-4">
              <h4 class="text-muted">No hay HUs en este sprint</h4>
              <p class="text-muted">Este sprint está vacío. ¡Ánimo con la planificación!</p>
            </div>
          <% } else { %>
            <div class="text-center py-5">
              <img src="https://illustrations.popsy.co/blue/work-from-home.svg" alt="No Sprint" style="width: 200px;" class="mb-4">
              <h4 class="text-muted">¡Listos para despegar!</h4>
              <p class="text-muted">No hay ningún sprint activo. Haz clic en el botón para comenzar uno nuevo.</p>
              <button class="btn btn-primary mt-3 rounded-pill px-4" onclick="showModal()">Iniciar Primer Sprint</button>
            </div>
          <% } %>
        </div>
      </div>

      <div class="text-center mt-5 mb-5">
        <a href="/<%= project_id %>/sprint-pasado" class="text-white text-decoration-none opacity-75 hover-opacity-100">
          <i class="bi bi-clock-history me-1"></i> Ver historial de sprints pasados
        </a>
      </div>
    </div>

    <%- include('partials/ModalCrearSprint') %>
    <%- include('partials/footer') %>

    <script>
      function showModal() {
        document.getElementById("modal-new-sprint").classList.add("show");
      }
      function hideModal() {
        document.getElementById("modal-new-sprint").classList.remove("show");
      }
    </script>
  </body>
</html>
